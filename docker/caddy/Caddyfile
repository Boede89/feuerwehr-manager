# HTTPS-Reverse-Proxy für Feuerwehr-Manager (LAN)
# Bevorzugt: fw-manager.home.arpa (DNS Rewrite im Router/AdGuard)
# Fallback: direkte IP/Hostname auf Port 80/443 (z. B. https://192.168.10.123)
# Debug: http://<IP>:8080 (App direkt, ohne Caddy)
#
# Für öffentliche Domain + Let's Encrypt: siehe Caddyfile.domain.example

{
	admin off
}

http://fw-manager.home.arpa {
	redir https://fw-manager.home.arpa{uri} permanent
}

https://fw-manager.home.arpa {
	import ffm_https
}

# Fallback für Zugriff per IP oder anderem Hostnamen ohne DNS-Eintrag
:80 {
	redir https://{host}{uri} permanent
}

:443 {
	import ffm_https
}

(ffm_https) {
	tls internal
	encode gzip
	reverse_proxy app:8080 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Port 443
	}
}
