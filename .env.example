# Kopie als .env im Projektroot (nicht committen):
#   cp .env.example .env
# Dann Werte anpassen und: docker compose up -d --build

# Pflicht in Produktion (DSGVO): 2FA-Geheimnisse verschlüsselt in der DB
# Mindestens 32 Zeichen, zufällig — z. B. openssl rand -base64 48
FEUERWEHR_TOTP_ENCRYPTION_KEY=

# Starkes Initialpasswort (vor erstem Start setzen)
FEUERWEHR_BOOTSTRAP_ADMIN_PASSWORD=changeme

# Audit-Logs: IP nur gehasht — Salt in Produktion ändern
FEUERWEHR_AUDIT_SALT=bitte-in-produktion-aendern

# Optional
FEUERWEHR_DIVERA_POLL_ENABLED=false
FEUERWEHR_BOOTSTRAP_ADMIN_RESET_PASSWORD=false

# Einsatz-App: Firebase Cloud Messaging HTTP v1 (Dienstkonto-JSON — nicht committen)
FEUERWEHR_FCM_ENABLED=false
# Pfad im App-Container, z. B. nach Volume-Mount (siehe docker-compose.yml / docs/EINSATZ-APP.md)
FEUERWEHR_FCM_SERVICE_ACCOUNT_PATH=/data/fcm-service-account.json

# Session-Cookies: Secure nur bei HTTPS (inkl. Reverse-Proxy). HTTP auf :8080 bleibt zum Debuggen nutzbar.
FEUERWEHR_SESSION_COOKIE_SECURE=true

# Optional: CUPS-Druck — funktioniert ohne .env-Anpassung (Web-UI http://<Host>:631, Benutzer print, Passwort print)
# Drucker automatisch anlegen (pro Standort einmal, IP statt Hostname — siehe docs/DRUCK.md):
# CUPS_PRINTER_HOST=192.168.1.50
# oder vollständig:
# CUPS_PRINTER_URI=ipp://192.168.1.50/ipp/print
# CUPS_PRINTER_NAME=Zentrale

# Secure-Cookies komplett deaktivieren (nur Entwicklung):
# FEUERWEHR_SESSION_COOKIE_SECURE=false
